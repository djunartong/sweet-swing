# .env.example
#
# This is a TEMPLATE file — it is safe to commit to GitHub because
# it contains no real values, only placeholder descriptions.
#
# To set up the project locally:
#   1. Copy this file:  cp .env.example .env
#   2. Open .env and replace each placeholder with your real value
#   3. Never commit your .env file to GitHub

# WhatsApp click-to-chat number (include country code, no + or spaces)
# Example: Singapore number +65 9123 4567 becomes 6591234567
VITE_WHATSAPP_NUMBER=your_whatsapp_number

# Telegram username (without the @ symbol)
VITE_TELEGRAM_USERNAME=your_telegram_username

# Elfsight widget id
VITE_ELFSIGHT_WIDGET_ID=your_elfsight_widget_id