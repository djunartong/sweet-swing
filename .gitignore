# .gitignore
#
# This file tells Git which files and folders to IGNORE —
# they will never be uploaded to GitHub, no matter what.
# Lines starting with # are comments.
 
# ── PRIVATE & SENSITIVE ──────────────────────────────────────────────────────
 
# Your real environment variables (passwords, API keys, private contact details)
# .env.example is NOT ignored — it is a safe template for other developers
.env
.env.local
.env.*.local
 
# ── DEPENDENCIES ─────────────────────────────────────────────────────────────
 
# The node_modules folder contains all installed packages.
# It can be huge (100,000+ files) and is always re-created by running:
#   npm install
# There is never a reason to upload it to GitHub.
node_modules/
 
# ── BUILD OUTPUT ─────────────────────────────────────────────────────────────
 
# The dist folder is generated by Vite when you run: npm run build
# It contains the final compiled site ready for deployment.
# It does not belong in source control — it is rebuilt on each deploy.
dist/
 
# ── EDITOR & OS FILES ────────────────────────────────────────────────────────
 
# VS Code editor settings (optional — remove this if you want to share
# your VS Code settings with teammates)
.vscode/
 
# macOS creates hidden .DS_Store files in every folder it touches.
# These are useless metadata files that should never be committed.
.DS_Store
 
# Windows equivalent of .DS_Store
Thumbs.db